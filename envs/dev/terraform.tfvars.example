# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored and must never be committed.

fb_url    = "10.10.10.2"
api_token = "T-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# S3 object store accounts. The map key is the account name.
s3_accounts = {
  "myteam" = {
    # quota      = "1T"
    # hard_limit = true
  }
}

# S3 buckets. The map key is the bucket name.
# account_name must reference a key in s3_accounts above.
buckets = {
  "my-bucket-1" = {
    account_name = "myteam"
    versioning   = "enabled"
    quota        = "100G"
    hard_limit   = false
    eradicate    = false
  }
  "my-bucket-2" = {
    account_name = "myteam"
    eradicate    = false
  }
}
